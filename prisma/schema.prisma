generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  editor
  partner
}

enum ContentStatus {
  draft
  published
  archived
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(editor)
  partnerId    String?
  partner      Partner?  @relation(fields: [partnerId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  recipes      Recipe[]  @relation("RecipeCreatedBy")
  prebatches   Prebatch[] @relation("PrebatchCreatedBy")
  drinks       Drink[]   @relation("DrinkCreatedBy")
}

model Partner {
  id              String   @id
  name            String
  nameEn          String
  isGeneralPartner Boolean @default(false)
  logo            String?
  description     String
  descriptionEn   String
  link            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  drinks          Drink[]
}

model DrinkCategory {
  id            String   @id
  slug          String   @unique
  name          String
  nameEn        String
  icon          String?
  description   String
  descriptionEn String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  drinks        Drink[]
}

model Drink {
  id            String        @id
  categoryId    String
  partnerId     String
  name          String
  nameEn        String
  image         String?
  description   String
  descriptionEn String
  status        ContentStatus @default(published)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category      DrinkCategory @relation(fields: [categoryId], references: [id])
  partner       Partner       @relation(fields: [partnerId], references: [id])

  createdById   String?
  createdBy     User?         @relation("DrinkCreatedBy", fields: [createdById], references: [id])

  @@index([categoryId])
  @@index([partnerId])
}

model Prebatch {
  id          String        @id @default(cuid())
  name        String
  ingredients String[]
  steps       String[]
  status      ContentStatus @default(published)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdById String?
  createdBy   User?         @relation("PrebatchCreatedBy", fields: [createdById], references: [id])

  recipes     Recipe[]
}

model Recipe {
  id             String        @id @default(cuid())
  slug           String        @unique
  city           String
  lat            Float
  lng            Float

  name           String
  region         String
  author         String
  bar            String
  difficulty     String
  category       String
  barDescription String
  barCity        String
  tags           String[]
  intro          String
  image          String
  method         String
  glass          String
  garnish        String
  ice            String

  prebatchMode   String        @default("text") // text|ref|none
  prebatchText   String?
  prebatchId     String?
  prebatch       Prebatch?     @relation(fields: [prebatchId], references: [id])

  flavorBitter   Int @default(0)
  flavorSweet    Int @default(0)
  flavorSour     Int @default(0)
  flavorSpicy    Int @default(0)
  flavorStrong   Int @default(0)

  ingredients    String[]
  steps          String[]

  authorInstagram String?
  authorTg        String?
  barLink         String?

  status         ContentStatus @default(published)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  createdById    String?
  createdBy      User?         @relation("RecipeCreatedBy", fields: [createdById], references: [id])

  @@index([status])
  @@index([region])
}

